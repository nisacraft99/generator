{
  "app": "TOPS",
  "scope": "OM Console > M3 Review",
  "nodes": [
    {
      "id": "CONSOLE-OM",
      "type": "console",
      "name": "OM Console",
      "parent": null
    },
    {
      "id": "OM-OPT-M3-REVIEW",
      "type": "nav_option",
      "name": "M3 Review",
      "parent": "CONSOLE-OM"
    },

    {
      "id": "SCR-M3-DASHBOARD",
      "type": "screen",
      "name": "M3 Dashboard",
      "parent": "OM-OPT-M3-REVIEW"
    },

    {
      "id": "COMP-M3-LIST",
      "type": "component",
      "name": "List of created M3 entries",
      "parent": "SCR-M3-DASHBOARD"
    },
    {
      "id": "EL-M3-IDENT-LINK",
      "type": "element",
      "name": "M3 Ident (row link)",
      "parent": "COMP-M3-LIST"
    },

    {
      "id": "EL-M3-CREATE",
      "type": "element",
      "name": "Create M3 button",
      "parent": "SCR-M3-DASHBOARD"
    },
    {
      "id": "EL-M3-FILTER",
      "type": "element",
      "name": "Filter button",
      "parent": "SCR-M3-DASHBOARD"
    },
    {
      "id": "EL-M3-EXPORT-EXCEL",
      "type": "element",
      "name": "Export to Excel button",
      "parent": "SCR-M3-DASHBOARD"
    },
    {
      "id": "EL-M3-REFRESH",
      "type": "element",
      "name": "Refresh button",
      "parent": "SCR-M3-DASHBOARD"
    },

    {
      "id": "SCR-M3-OVERVIEW",
      "type": "screen",
      "name": "M3 Overview",
      "parent": "SCR-M3-DASHBOARD"
    },
    {
      "id": "EL-M3-BACK",
      "type": "element",
      "name": "Back button (to Dashboard)",
      "parent": "SCR-M3-OVERVIEW"
    },

    {
      "id": "COMP-M3-ACTIONS-LIST",
      "type": "component",
      "name": "Actions list for selected M3 (incl. status started/not started)",
      "parent": "SCR-M3-OVERVIEW"
    },
    {
      "id": "EL-ACTION-STATUS",
      "type": "element",
      "name": "Action status indicator (started/not started)",
      "parent": "COMP-M3-ACTIONS-LIST"
    },
    {
      "id": "EL-M3-ADD-ACTION",
      "type": "element",
      "name": "Add action button",
      "parent": "SCR-M3-OVERVIEW"
    }
  ],

  "relationships": [
    {
      "type": "navigation",
      "from": "SCR-M3-DASHBOARD",
      "via": "EL-M3-IDENT-LINK",
      "to": "SCR-M3-OVERVIEW",
      "notes": "Clicking a specific M3 Ident opens Overview for that M3."
    },
    {
      "type": "navigation",
      "from": "SCR-M3-OVERVIEW",
      "via": "EL-M3-BACK",
      "to": "SCR-M3-DASHBOARD",
      "notes": "Back returns to dashboard list."
    }
  ],

  "action_registry": [
    {
      "action_key": "open_m3_dashboard",
      "synonyms": ["M3 Review öffnen", "M3 Dashboard öffnen", "go to M3 review"],
      "target_node": "SCR-M3-DASHBOARD"
    },
    {
      "action_key": "create_m3",
      "synonyms": ["M3 erstellen", "Create M3", "neues M3 anlegen"],
      "target_node": "EL-M3-CREATE"
    },
    {
      "action_key": "filter_m3_dashboard",
      "synonyms": ["M3 filtern", "Filter anwenden", "Dashboard filtern"],
      "target_node": "EL-M3-FILTER"
    },
    {
      "action_key": "export_m3_to_excel",
      "synonyms": ["Export to Excel", "M3 exportieren", "Excel Export"],
      "target_node": "EL-M3-EXPORT-EXCEL"
    },
    {
      "action_key": "refresh_m3_dashboard",
      "synonyms": ["Refresh", "Dashboard aktualisieren", "neu laden"],
      "target_node": "EL-M3-REFRESH"
    },
    {
      "action_key": "open_m3_overview",
      "synonyms": ["M3 Overview öffnen", "M3 Details anzeigen", "M3 Ident anklicken"],
      "target_node": "SCR-M3-OVERVIEW"
    },
    {
      "action_key": "add_action_to_m3",
      "synonyms": ["Action hinzufügen", "Add action", "Action zu M3 hinzufügen"],
      "target_node": "EL-M3-ADD-ACTION"
    },
    {
      "action_key": "back_to_m3_dashboard",
      "synonyms": ["Back", "zurück zum Dashboard", "zur Übersicht"],
      "target_node": "EL-M3-BACK"
    }
  ]
}
